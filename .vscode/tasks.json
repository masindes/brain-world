{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flask API",
      "type": "shell",
      "command": "python app.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "run"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "React Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "run"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run App",
      "dependsOn": ["Flask API", "React Dev Server"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
